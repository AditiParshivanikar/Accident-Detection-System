{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:8000/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "ws://localhost:8000/ws/:path*"
    }
  ]
}
